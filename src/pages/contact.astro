---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { CONTACT_INFO } from '../lib/constants';
---

<Layout title="Contact Us | SERVSMOVING LLC">
  <Header />

  <main class="page-main">
    <!-- Success Alert -->
    <div id="success-alert" class="success-alert hidden">
      <div class="alert-content glass-panel">
        <div class="alert-icon">✨</div>
        <div class="alert-text">
          <h3>Request Sent Successfully!</h3>
          <p>Thank you for reaching out. We've received your quote request and will get back to you shortly.</p>
        </div>
        <button id="close-alert" class="close-btn">&times;</button>
      </div>
    </div>

    <section class="section header-section">
      <div class="container center">
        <span class="section-subtitle">GET IN TOUCH</span>
        <h1 class="page-title">Contact Us</h1>
        <p class="section-description">Ready to move? Request a free quote or give us a call today.</p>
      </div>
    </section>

    <section class="section contact-section" style="padding-top: 0;">
      <div class="container">
        <div class="grid grid-2 contact-grid">
          <div class="contact-info-panel animate-fade-in-up">
            <h2 style="font-size: 2rem; margin-bottom: 2rem;">Contact Information</h2>
            
            <div class="info-blocks">
              <div class="info-block glass-panel">
                <div class="icon">📞</div>
                <div>
                  <h3>Phone</h3>
                  <p>{CONTACT_INFO.phone}</p>
                </div>
              </div>
              
              <div class="info-block glass-panel">
                <div class="icon">✉️</div>
                <div>
                  <h3>Email</h3>
                  <p>{CONTACT_INFO.email}</p>
                </div>
              </div>
              
              <div class="info-block glass-panel">
                <div class="icon">📍</div>
                <div>
                  <h3>Location</h3>
                  <p>Livermore, CA<br/>Serving the Bay Area, Alameda County, Pleasanton, and Dublin.</p>
                </div>
              </div>
            </div>
          </div>
          
          <div class="contact-form-panel glass-panel animate-scale-in delay-200">
            <h2 style="font-size: 2rem; margin-bottom: 2rem;">Request a Free Quote</h2>
            <form class="contact-form" action={CONTACT_INFO.formSubmitUrl} method="POST">
              <!-- FormSubmit Configuration -->
              <input type="hidden" name="_subject" value={CONTACT_INFO.formSubject}>
              <input type="hidden" name="_template" value="table">
              <input type="hidden" name="_next" value={Astro.site ? new URL('/contact/?success=true', Astro.site).href : Astro.url.origin + "/contact/?success=true"}>

              <div class="grid grid-2" style="gap: 1.5rem; margin-bottom: 1.5rem;">
                <div class="form-group" style="margin-bottom: 0;">
                  <label for="name">Name</label>
                  <input type="text" name="name" id="name" required placeholder="John Doe">
                </div>
                
                <div class="form-group" style="margin-bottom: 0;">
                  <label for="phone">Phone Number</label>
                  <input type="tel" name="phone" id="phone" required placeholder={CONTACT_INFO.phone}>
                </div>
              </div>

              <div class="grid grid-2" style="gap: 1.5rem; margin-bottom: 1.5rem;">
                <div class="form-group" style="margin-bottom: 0;">
                  <label for="moving-from">Moving From</label>
                  <input type="text" name="moving_from" id="moving-from" required placeholder="Current Address">
                </div>
                
                <div class="form-group" style="margin-bottom: 0;">
                  <label for="moving-to">Moving To</label>
                  <input type="text" name="moving_to" id="moving-to" required placeholder="Destination Address">
                </div>
              </div>

              <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" name="email" id="email" required placeholder="name@example.com">
              </div>

              <div class="form-group">
                <label for="fb-link">Your Facebook Profile Link</label>
                <input type="url" name="fb_link" id="fb-link" required placeholder="https://facebook.com/yourprofile">
              </div>
              
              <button type="submit" class="btn-primary" style="width: 100%;">Submit Request</button>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .page-main {
    padding-top: 100px;
  }
  
  .header-section {
    padding: 4rem 0;
  }

  .page-title {
    font-size: 3.5rem;
    margin-bottom: 1rem;
    background: linear-gradient(to right, var(--text-main), var(--text-muted));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .contact-grid {
    gap: 4rem;
  }

  .info-blocks {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .info-block {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem;
  }

  .info-block .icon {
    font-size: 2rem;
    background: rgba(245, 158, 11, 0.1);
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
  }

  .info-block h3 {
    margin-bottom: 0.5rem;
    font-size: 1.2rem;
  }

  .info-block p {
    color: var(--text-muted);
  }

  .contact-form-panel {
    padding: 3rem;
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 500;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    color: var(--text-main);
    font-family: 'Inter', sans-serif;
    transition: all 0.3s ease;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--accent);
    background: rgba(255, 255, 255, 0.08);
  }

  /* Success Alert Styles */
  .success-alert {
    position: fixed;
    top: 120px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1000;
    width: 90%;
    max-width: 600px;
    animation: slideDown 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
  }

  .success-alert.hidden {
    display: none;
  }

  .alert-content {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem 2rem;
    border: 1px solid rgba(34, 197, 94, 0.3);
    background: rgba(10, 10, 12, 0.8);
    backdrop-filter: blur(12px);
  }

  .alert-icon {
    font-size: 2rem;
    background: rgba(34, 197, 94, 0.1);
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #22c55e;
  }

  .alert-text h3 {
    color: #22c55e;
    font-size: 1.25rem;
    margin-bottom: 0.25rem;
  }

  .alert-text p {
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  .close-btn {
    background: none;
    border: none;
    color: var(--text-muted);
    font-size: 1.5rem;
    cursor: pointer;
    margin-left: auto;
    transition: color 0.3s ease;
  }

  .close-btn:hover {
    color: var(--text-main);
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translate(-50%, -20px);
    }
    to {
      opacity: 1;
      transform: translate(-50%, 0);
    }
  }

  @media (max-width: 640px) {
    .alert-content {
      padding: 1rem;
      gap: 1rem;
    }
    .alert-icon {
      width: 40px;
      height: 40px;
      font-size: 1.5rem;
    }
  }
</style>

<script>
  // Check for success query parameter
  const urlParams = new URLSearchParams(window.location.search);
  const isSuccess = urlParams.get('success');
  const alert = document.getElementById('success-alert');
  const closeBtn = document.getElementById('close-alert');

  if (isSuccess === 'true' && alert) {
    alert.classList.remove('hidden');
    
    // Auto-hide after 10 seconds
    const timeout = setTimeout(() => {
      alert.style.opacity = '0';
      alert.style.transition = 'opacity 0.5s ease';
      setTimeout(() => alert.classList.add('hidden'), 500);
    }, 10000);

    if (closeBtn) {
      closeBtn.addEventListener('click', () => {
        alert.classList.add('hidden');
        clearTimeout(timeout);
      });
    }

    // Clean up URL without refreshing the page
    const newUrl = window.location.pathname;
    window.history.replaceState({}, document.title, newUrl);
  }
</script>
