---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact Us | SERVSMOVING LLC">
  <Header />

  <main class="page-main">
    <section class="section header-section">
      <div class="container center">
        <span class="section-subtitle">GET IN TOUCH</span>
        <h1 class="page-title">Contact Us</h1>
        <p class="section-description">Ready to move? Request a free quote or give us a call today.</p>
      </div>
    </section>

    <section class="section contact-section" style="padding-top: 0;">
      <div class="container">
        <div class="grid grid-2 contact-grid">
          <div class="contact-info-panel animate-fade-in-up">
            <h2 style="font-size: 2rem; margin-bottom: 2rem;">Contact Information</h2>
            
            <div class="info-blocks">
              <div class="info-block glass-panel">
                <div class="icon">📞</div>
                <div>
                  <h3>Phone</h3>
                  <p>0907-888-0557</p>
                </div>
              </div>
              
              <div class="info-block glass-panel">
                <div class="icon">✉️</div>
                <div>
                  <h3>Email</h3>
                  <p>servsmovingllc@gmail.com</p>
                </div>
              </div>
              
              <div class="info-block glass-panel">
                <div class="icon">📍</div>
                <div>
                  <h3>Location</h3>
                  <p>Livermore, CA<br/>Serving the Bay Area, Alameda County, Pleasanton, and Dublin.</p>
                </div>
              </div>
            </div>
          </div>
          
          <div class="contact-form-panel glass-panel animate-scale-in delay-200">
            <h2 style="font-size: 2rem; margin-bottom: 2rem;">Request a Free Quote</h2>
            <form class="contact-form" id="quoteForm">
              <div class="grid grid-2" style="gap: 1.5rem; margin-bottom: 1.5rem;">
                <div class="form-group" style="margin-bottom: 0;">
                  <label for="name">Name</label>
                  <input type="text" id="name" required placeholder="John Doe">
                </div>
                
                <div class="form-group" style="margin-bottom: 0;">
                  <label for="phone">Phone Number</label>
                  <input type="tel" id="phone" required placeholder="0907-888-0557">
                </div>
              </div>

              <div class="grid grid-2" style="gap: 1.5rem; margin-bottom: 1.5rem;">
                <div class="form-group" style="margin-bottom: 0;">
                  <label for="moving-from">Moving From</label>
                  <input type="text" id="moving-from" required placeholder="Current Address">
                </div>
                
                <div class="form-group" style="margin-bottom: 0;">
                  <label for="moving-to">Moving To</label>
                  <input type="text" id="moving-to" required placeholder="Destination Address">
                </div>
              </div>

              <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" required placeholder="name@example.com">
              </div>

              <div class="form-group">
                <label for="fb-link">Your Facebook Profile Link</label>
                <input type="url" id="fb-link" required placeholder="https://facebook.com/yourprofile">
              </div>
              
              <button type="submit" class="btn-primary" style="width: 100%;">Submit Request</button>
            </form>

            <script is:inline>
              document.getElementById('quoteForm')?.addEventListener('submit', (e) => {
                e.preventDefault();
                
                const name = document.getElementById('name').value;
                const phone = document.getElementById('phone').value;
                const movingFrom = document.getElementById('moving-from').value;
                const movingTo = document.getElementById('moving-to').value;
                const email = document.getElementById('email').value;
                const fbLink = document.getElementById('fb-link').value;
                
                const message = `🚚 NEW QUOTE REQUEST\n\n` +
                                `👤 Name: ${name}\n` +
                                `📞 Phone: ${phone}\n` +
                                `📧 Email: ${email}\n` +
                                `🏠 Moving From: ${movingFrom}\n` +
                                `📍 Moving To: ${movingTo}\n` +
                                `🔗 Client FB: ${fbLink}`;
                
                // Facebook Account: jacalan.ma.louise
                const encodedMsg = encodeURIComponent(message);
                
                // Copy to clipboard silently as the ultimate fallback
                navigator.clipboard.writeText(message).catch(() => {});

                // Using messenger.com which is often more reliable for text pre-filling than facebook.com
                const messengerUrl = `https://www.messenger.com/t/jacalan.ma.louise?text=${encodedMsg}`;

                // Open Messenger
                window.open(messengerUrl, '_blank');
              });
            </script>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .page-main {
    padding-top: 100px;
  }
  
  .header-section {
    padding: 4rem 0;
  }

  .page-title {
    font-size: 3.5rem;
    margin-bottom: 1rem;
    background: linear-gradient(to right, var(--text-main), var(--text-muted));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .contact-grid {
    gap: 4rem;
  }

  .info-blocks {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .info-block {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem;
  }

  .info-block .icon {
    font-size: 2rem;
    background: rgba(245, 158, 11, 0.1);
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
  }

  .info-block h3 {
    margin-bottom: 0.5rem;
    font-size: 1.2rem;
  }

  .info-block p {
    color: var(--text-muted);
  }

  .contact-form-panel {
    padding: 3rem;
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 500;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    color: var(--text-main);
    font-family: 'Inter', sans-serif;
    transition: all 0.3s ease;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--accent);
    background: rgba(255, 255, 255, 0.08);
  }
</style>
