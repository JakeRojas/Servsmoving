---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

import { ADMIN_CONFIG } from '../../lib/constants';

import { supabase } from '../../lib/supabase';

export const prerender = false;

const adminPassword = ADMIN_CONFIG.password;
const cookiePass = Astro.cookies.get('admin_pass')?.value;
const isAdmin = adminPassword && cookiePass && cookiePass.trim() === adminPassword.trim();

// Show error if user attempted to login but failed
const loginAttempted = !!cookiePass;
const loginFailed = loginAttempted && !isAdmin;

if (!adminPassword && process.env.NODE_ENV === 'development') {
  console.error('CRITICAL ERROR: ADMIN_PASSWORD is not set in .env. Login will not work.');
}

// Get images from Supabase Storage
const { data: storageFiles, error: storageError } = await supabase.storage
  .from('gallery')
  .list('', {
    limit: 100,
    offset: 0,
    sortBy: { column: 'name', order: 'desc' },
  });

const galleryImages = storageFiles?.map(file => ({
  filename: file.name,
  src: supabase.storage.from('gallery').getPublicUrl(file.name).data.publicUrl
})) || [];

if (storageError) {
  console.error('Supabase Storage Error:', storageError);
}
---

<Layout title="Gallery Admin | SERVSMOVING LLC">
  <Header />

  <main class="page-main">
    <section class="section header-section">
      <div class="container center">
        <span class="section-subtitle">ADMIN PANEL</span>
        <h1 class="page-title">Gallery Management</h1>
        <p class="section-description">Upload and organize images for the public gallery.</p>
        
        {!adminPassword && (
          <div class="error-banner glass-panel" style="margin-top: 2rem; border-color: #ef4444;">
            <p style="color: #ef4444; font-weight: bold;">⚠️ Server Configuration Error: ADMIN_PASSWORD is missing in .env</p>
          </div>
        )}
      </div>
    </section>

    <section class="section admin-section" style="padding-top: 0;">
      <div class="container">
        {!isAdmin ? (
          <div class="login-container glass-panel animate-scale-in">
            <h2 style="margin-bottom: 1.5rem;">Admin Access</h2>
            <form id="login-form">
              <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" required placeholder="Enter admin password" autocomplete="current-password" />
              </div>
              <button type="submit" class="btn-primary" style="width: 100%;" disabled={!adminPassword}>
                {adminPassword ? 'Login' : 'Login Disabled'}
              </button>
              {loginFailed && (
                <p id="login-error" class="error-msg">Incorrect password. Please try again.</p>
              )}
            </form>
          </div>
        ) : (
          <div class="gallery-admin-grid">
            <!-- Upload Frame -->
            <div id="upload-frame" class="gallery-item upload-frame glass-panel animate-fade-in-up">
              <div class="upload-content">
                <span class="upload-icon">➕</span>
                <p>Click to Upload Image</p>
                <input type="file" id="file-input" accept="image/*" class="hidden" />
              </div>
              <div id="upload-overlay" class="overlay hidden">
                <div class="spinner"></div>
                <p>Uploading...</p>
              </div>
            </div>

            {galleryImages.map((img, i) => (
              <div class={`gallery-item glass-panel animate-fade-in-up delay-${(i % 3 + 1) * 100}`} data-filename={img.filename}>
                <div class="img-wrapper">
                  <img src={img.src} alt={img.filename} loading="lazy" />
                  <button class="delete-btn" aria-label="Delete Image" data-filename={img.filename}>
                    <span class="trash-icon">🗑️</span>
                  </button>
                </div>
              </div>
            ))}
          </div>
          <div class="admin-actions">
            <button id="logout-btn" class="btn-outline">Logout</button>
          </div>
        )}
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .page-main {
    padding-top: 100px;
    min-height: 80vh;
  }
  
  .header-section {
    padding: 4rem 0;
  }

  .login-container {
    max-width: 400px;
    margin: 0 auto;
    padding: 3rem;
    text-align: center;
  }

  .form-group {
    margin-bottom: 1.5rem;
    text-align: left;
  }

  .form-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 500;
  }

  .form-group input {
    width: 100%;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    color: var(--text-main);
  }

  .error-msg {
    color: #ef4444;
    font-size: 0.875rem;
    margin-top: 1rem;
  }

  .hidden {
    display: none !important;
  }

  .gallery-admin-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
  }

  .gallery-item {
    position: relative;
    overflow: hidden;
    padding: 0.5rem;
    height: 320px;
    transition: transform 0.3s ease;
  }

  .upload-frame {
    border: 2px dashed var(--accent);
    background: rgba(245, 158, 11, 0.03);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .upload-frame:hover {
    background: rgba(245, 158, 11, 0.08);
    transform: translateY(-5px);
  }

  .upload-content p {
    margin-top: 1rem;
    font-weight: 600;
    color: var(--accent);
  }

  .upload-icon {
    font-size: 3rem;
  }

  .img-wrapper {
    position: relative;
    height: 100%;
    border-radius: 8px;
    overflow: hidden;
  }

  .img-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .delete-btn {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: rgba(239, 68, 68, 0.9);
    color: white;
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    transition: all 0.3s ease;
    transform: translateY(-10px);
  }

  .gallery-item:hover .delete-btn {
    opacity: 1;
    transform: translateY(0);
  }

  .delete-btn:hover {
    background: #dc2626;
    transform: scale(1.1);
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 10;
  }

  .spinner {
    width: 40px;
    height: 40px;
    border: 3px solid rgba(255, 255, 255, 0.3);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin-bottom: 1rem;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .admin-actions {
    margin-top: 4rem;
    display: flex;
    justify-content: flex-end;
  }
</style>

<script>
  // Login Logic
  const loginForm = document.getElementById('login-form');
  const loginError = document.getElementById('login-error');

  if (loginForm) {
    loginForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const password = (document.getElementById('password') as HTMLInputElement).value;
      // In a real app, we would verify with an API, but for simplicity and security:
      document.cookie = `admin_pass=${password}; path=/; max-age=86400; SameSite=Strict`;
      window.location.reload();
    });
  }

  // Logout Logic
  const logoutBtn = document.getElementById('logout-btn');
  if (logoutBtn) {
    logoutBtn.addEventListener('click', () => {
      document.cookie = "admin_pass=; path=/; expires=Thu, 01 Jan 1970 00:00:00 UTC;";
      window.location.reload();
    });
  }

  // Upload Logic
  const uploadFrame = document.getElementById('upload-frame');
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const overlay = document.getElementById('upload-overlay');

  if (uploadFrame && fileInput) {
    uploadFrame.addEventListener('click', () => fileInput.click());

    fileInput.addEventListener('change', async () => {
      const file = fileInput.files?.[0];
      if (!file) return;

      overlay?.classList.remove('hidden');

      const formData = new FormData();
      formData.append('image', file);
      formData.append('action', 'upload');
      formData.append('password', getCookie('admin_pass') || '');

      try {
        const res = await fetch('/api/gallery', {
          method: 'POST',
          body: formData
        });

        const result = await res.json();

        if (res.ok) {
          window.location.reload();
        } else {
          alert(`Upload failed: ${result.error || 'Check your password or server config.'}`);
          overlay?.classList.add('hidden');
        }
      } catch (err) {
        alert('An error occurred during upload. Check your connection.');
        overlay?.classList.add('hidden');
      }
    });
  }

  // Delete Logic
  const deleteBtns = document.querySelectorAll('.delete-btn');
  deleteBtns.forEach(btn => {
    btn.addEventListener('click', async (e) => {
      e.stopPropagation();
      const filename = (btn as HTMLElement).dataset.filename;
      if (!filename || !confirm(`Are you sure you want to delete ${filename}?`)) return;

      const formData = new FormData();
      formData.append('filename', filename);
      formData.append('action', 'delete');
      formData.append('password', getCookie('admin_pass') || '');

      try {
        const res = await fetch('/api/gallery', {
          method: 'POST',
          body: formData
        });

        if (res.ok) {
          window.location.reload();
        } else {
          const errData = await res.json();
          alert(`Delete failed: ${errData.error || 'Server error'}`);
        }
      } catch (err) {
        alert('An error occurred during deletion.');
      }
    });
  });

  function getCookie(name: string) {
    const value = `; ${document.cookie}`;
    const parts = value.split(`; ${name}=`);
    if (parts.length === 2) return parts.pop()?.split(';').shift();
  }
</script>
