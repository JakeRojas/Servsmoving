---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

import { supabase } from '../lib/supabase';

// Get images from Supabase Storage
const { data: storageFiles, error: storageError } = await supabase.storage
  .from('gallery')
  .list('', {
    limit: 100,
    offset: 0,
    sortBy: { column: 'name', order: 'desc' },
  });

const galleryImages = storageFiles?.map(file => ({
  filename: file.name,
  src: supabase.storage.from('gallery').getPublicUrl(file.name).data.publicUrl
})) || [];

if (storageError) {
  console.error('Supabase Storage Error:', storageError);
}
---

<Layout title="Gallery | SERVSMOVING LLC">
  <Header />

  <main class="page-main">
    <section class="section header-section">
      <div class="container center">
        <span class="section-subtitle">OUR WORK</span>
        <h1 class="page-title">Gallery</h1>
        <p class="section-description">A look at some of the moves we've completed recently across the Bay Area.</p>
      </div>
    </section>

    <section class="section gallery-section" style="padding-top: 0;">
      <div class="container">
        <div class="grid grid-3 gallery-grid">
          {galleryImages.length > 0 ? (
            galleryImages.map((img, i) => (
              <div class={`gallery-item glass-panel animate-fade-in-up delay-${(i % 3 + 1) * 100}`}>
                <div class="img-wrapper">
                  <img src={img.src} alt="Gallery image" loading="lazy" />
                </div>
              </div>
            ))
          ) : (
            <div class="center" style="grid-column: 1 / -1; padding: 4rem;">
              <p style="color: var(--text-muted);">No images in the gallery yet.</p>
            </div>
          )}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .page-main {
    padding-top: 100px;
  }
  
  .header-section {
    padding: 4rem 0;
  }

  .page-title {
    font-size: 3.5rem;
    margin-bottom: 1rem;
    background: linear-gradient(to right, var(--text-main), var(--text-muted));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .gallery-item {
    overflow: hidden;
    padding: 0.5rem;
  }

  .img-wrapper {
    height: 350px;
    background: var(--bg-color);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    overflow: hidden;
  }

  .img-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .gallery-item:hover .img-wrapper img {
    transform: scale(1.05);
  }
</style>
