---
import '../styles/global.css';
interface Props {
	title: string;
	description?: string;
}

const { title, description = "SERVSMOVING LLC - Save Better, Move Better. Licensed household moving service operating in Bay Area, Alameda County, Livermore, Pleasanton, and Dublin." } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
